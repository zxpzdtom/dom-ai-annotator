{
  "manifest_version": 3,
  "name": "DOM Review",
  "description": "在网页元素上记录 UI 反馈，并导出给 AI 或开发处理。",
  "version": "0.2.0",
  "permissions": ["activeTab", "storage", "sidePanel", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "DOM Review",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "devtools_page": "src/devtools/index.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["monitorBridge.js", "agentBridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "Alt+Shift+C"
      },
      "description": "打开或关闭 DOM Review"
    },
    "start-picking": {
      "description": "选择页面元素"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.js", "monitorBridge.js", "jsonViewerVendor.js", "chunks/*.js", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
